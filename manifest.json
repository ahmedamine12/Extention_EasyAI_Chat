{
  "manifest_version": 3,
  "name": "BrowseMate",
  "version": "2.0.0",
  "description": "BrowseMate V2 — floating AI chat with OpenAI, Gemini & Hugging Face, voice input, page screenshots, reminders, dark mode. Keys stay on your device.",
  "author": "BrowseMate Team",
  "homepage_url": "https://ahmedamine12.github.io/Extention_EasyAI_Chat/homepage.html",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "BrowseMate Settings",
    "default_icon": {
      "16": "icons/easyChat.png",
      "32": "icons/easyChat.png",
      "48": "icons/easyChat.png",
      "128": "icons/easyChat.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["utils/provider-config.js", "utils/provider-helpers.js", "utils/page-detection.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "settings/settings.html",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "contextMenus",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/easyChat.png",
    "32": "icons/easyChat.png",
    "48": "icons/easyChat.png",
    "128": "icons/easyChat.png"
  },
  "commands": {
    "toggle-chat": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Show or hide BrowseMate on this page"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/easyChat.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "minimum_chrome_version": "88"
} 